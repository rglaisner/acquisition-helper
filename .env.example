# Required: Google Gemini API key for CrewAI LLM
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Serper web search (Explorer + Deal Sourcer agents)
SERPER_API_KEY=your_serper_api_key_here

# Token budget ceiling before HITL approval (default: 500000)
TOKEN_BUDGET=500000

# Control profile: conservative | standard | aggressive
CONTROL_PROFILE=standard

# Default LLM model (lite tier)
LLM_MODEL_LITE=gemini/gemini-2.0-flash

# Pro model for Expert tier QA agents
LLM_MODEL_PRO=gemini/gemini-2.0-flash

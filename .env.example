# Required: Google Gemini API key for CrewAI LLM
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Serper web search (Explorer + Deal Sourcer agents)
SERPER_API_KEY=your_serper_api_key_here

# Token budget ceiling before HITL approval (default: unlimited)
# Set a positive integer to enforce a ceiling, e.g. TOKEN_BUDGET=500000

# Control profile: conservative | standard | aggressive
CONTROL_PROFILE=standard

# Default LLM model (lite tier). Use format provider/model_name compatible with CrewAI LLM class
LLM_MODEL_LITE=gemini/gemini-2.5-flash-lite

# Pro model for Expert tier QA agents. Use format provider/model_name compatible with CrewAI LLM class
LLM_MODEL_PRO=gemini/gemini-3-flash-preview

# Enable tracing for CrewAI
CREWAI_TRACING_ENABLED=true

# Set Tier: essential | standard | advanced | expert
TIER=expert